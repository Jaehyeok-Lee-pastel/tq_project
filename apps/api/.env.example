APP_NAME=app-api
APP_ENV=local
# Railway에서는 production으로 설정하세요. Railway 환경변수가 감지되면
# 코드가 자동으로 fail-closed 운영 모드를 사용합니다.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase (server-side: service_role is backend-only, never expose to web)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# OpenAI coach. Strategy engine works without this key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
AI_MAX_OUTPUT_TOKENS=900
AI_REQUEST_TIMEOUT_SECONDS=20

# Market data proxy
MARKET_DATA_PROVIDER=yahoo
MARKET_DATA_API_KEY=
