# Root reference for environment variables.
# Each app reads its OWN .env: apps/api/.env and apps/web/.env.local.
# Copy this as a checklist; do not commit real .env files.

# --- apps/api (.env) ---
APP_NAME=app-api
APP_ENV=local
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
AI_MAX_OUTPUT_TOKENS=900
AI_REQUEST_TIMEOUT_SECONDS=20
MARKET_DATA_PROVIDER=yahoo
MARKET_DATA_API_KEY=

# --- apps/web (.env.local) ---
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
