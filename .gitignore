# Dependencies
node_modules/
.venv/
__pycache__/
*.pyc

# Env
.env
.env.local
.env.*.local

# Build outputs
dist/
build/
.vite/
*.tsbuildinfo

# Local/private app data
apps/api/data/*.json

# Local agent/runtime workdirs
.claude/
.codex/
.gemini/
