# Keep local CI templates out of the first Railway deploy push.
.github/workflows/

# Logs
*.log

# Orchestration runtime (keep config, ignore generated logs/state)
.claude/logs/*.jsonl
.claude/logs/implementation-state.json

# IDE
.idea/
.vscode/
